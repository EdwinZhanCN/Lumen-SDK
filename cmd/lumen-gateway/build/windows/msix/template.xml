<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="lumen-gateway"
        Arguments=""
        InstallLocation="C:\Program Files\My Company\Lumen Gateway">
    </Installer>
    <PackageInformation
        PackageName="Lumen Gateway"
        PackageDisplayName="Lumen Gateway"
        PublisherName="CN=My Company"
        PublisherDisplayName="My Company"
        Version="0.1.0.0"
        PackageDescription="Lumen AI Distributed Inference Gateway">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.lumen.gateway"
                Description="Lumen AI Distributed Inference Gateway"
                DisplayName="Lumen Gateway"
                ExecutableName="lumen-gateway"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Lumen Gateway</DisplayName>
            <PublisherDisplayName>My Company</PublisherDisplayName>
            <Description>Lumen AI Distributed Inference Gateway</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="lumen-gateway.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
